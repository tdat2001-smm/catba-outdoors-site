# Telegram bot credentials for the booking bridge.
# Copy this file to `.env` for local dev with `vercel dev`,
# and set the same vars in your Vercel project (Settings → Environment Variables).

# 1. Create a bot with @BotFather, then paste the token below.
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUvwxyz

# 2. Chat ID where bookings should be delivered.
#    - Personal: send /start to your bot, then run `npm run telegram:get-chat-id`
#    - Group:    add the bot to the group, send any message, then run the same script
TELEGRAM_CHAT_ID=123456789

# Optional: restrict CORS for the /api/booking endpoint.
# Use comma-separated origins, or "*" for any.
# ALLOWED_ORIGIN=https://catbaoutdoors.vn,https://www.catbaoutdoors.vn
